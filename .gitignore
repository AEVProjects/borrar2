# =============================================
# Proyecto MSI Workflow - .gitignore
# =============================================

# --- Vercel ---
.vercel

# --- Node ---
node_modules/
package-lock.json

# --- Configuración con valores reales (NO subir a Git) ---
config.js

# --- n8n-as-code ---
# Archivo de configuración local de n8n-as-code (contiene API key)
.n8n-as-code.json
n8nac-config.json
workflows/**/.n8n-state.json

# --- Workflows con credenciales embebidas (NO subir a Git) ---
workflows/video-gen.json

# --- n8n workflow files (as-code) - managed by n8n, not Vercel ---
workflows/n8nmsi_cloud_n8n_m/

# --- Variables de entorno ---
.env
.env.local
.env*.local

# --- Datos sensibles/privados ---
data/*.csv

# --- OS ---
.DS_Store
Thumbs.db

# --- Editor ---
.vscode/
.idea/
*.swp
*.swo
*~