{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "styles.css", "use": "@vercel/static" },
    { "src": "app.js", "use": "@vercel/static" },
    { "src": "config.js", "use": "@vercel/static" },
    { "src": "config.example.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/calls(.*)",  "dest": "/api/calls.js"  },
    { "src": "/api/health", "dest": "/api/health.js" },
    { "src": "/styles.css",         "dest": "/styles.css"         },
    { "src": "/app.js",             "dest": "/app.js"             },
    { "src": "/config.js",          "dest": "/config.js"          },
    { "src": "/config.example.js",  "dest": "/config.example.js"  },
    { "src": "/(.*)",               "dest": "/index.html"         }
  ]
}
